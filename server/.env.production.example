# ─── TapMenu Server — PRODUCTION (Render.com Free Tier) ──────────────────────
# Copy these values to Render → Environment Variables
# DO NOT commit this file to git

NODE_ENV=production
PORT=10000
API_PREFIX=/api/v1

# MongoDB Atlas Free M0 cluster
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/tapmenu?retryWrites=true&w=majority

# Generate strong secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=<generate-32-char-hex>
JWT_REFRESH_SECRET=<generate-32-char-hex>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Production cookies
COOKIE_DOMAIN=<your-render-domain>.onrender.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# Render free Redis (if using Render Redis add-on) or leave blank
REDIS_URL=

# CORS — your Vercel frontend URL
CORS_ORIGIN=https://<your-app>.vercel.app

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Cloudinary free tier
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# Razorpay (use test keys while validating)
RAZORPAY_KEY_ID=rzp_live_<key>
RAZORPAY_KEY_SECRET=<secret>

# Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your-gmail>@gmail.com
EMAIL_PASS=<gmail-app-password>
EMAIL_FROM=TapMenu <<your-gmail>@gmail.com>

CLIENT_URL=https://<your-app>.vercel.app

LOG_LEVEL=warn
